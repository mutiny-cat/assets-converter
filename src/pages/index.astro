---
/**
 * Pàgina principal del convertidor d'actius.
 * Renderitza la interfície amb pestanyes (Imatges, Vectors, Fonts),
 * els panells de configuració, els navegadors d'arbre de directoris
 * i la galeria de previsualització. El client JS (/public/app.js)
 * gestiona tota la interactivitat.
 */
import os from "node:os"
import "../styles/global.css"

const HOME = os.homedir()
---

<!doctype html>
<html lang="ca" data-home={HOME}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <title>Assets Converter</title>
</head>
<body>
  <main class="main">
    <h1>Assets Converter</h1>
    <button class="btn-shutdown" id="shutdownBtn" type="button" title="Aturar el servidor"><span class="shutdown-icon">⏻</span> Sortir de l'aplicació</button>

    <!-- Modal de confirmació per tancar el servidor -->
    <div class="modal-overlay hidden" id="shutdownModal">
      <div class="modal-box">
        <p class="modal-text">Segur que vols aturar el servidor?</p>
        <div class="modal-actions">
          <button class="btn-secondary" id="modalCancel">Cancel·lar</button>
          <button class="btn-primary" id="modalConfirm" style="background:var(--red)">Aturar</button>
        </div>
      </div>
    </div>
    <p class="subtitle">Convertidor d'actius local: imatges a WebP, optimització SVG i fonts a WOFF2</p>

    <div class="tool-tabs" id="toolTabs">
      <button class="tool-tab active" data-tool="imatges">Imatges → WebP</button>
      <button class="tool-tab" data-tool="vectors">Vectors SVG</button>
      <button class="tool-tab" data-tool="fonts">Fonts → WOFF2</button>
    </div>

    <div class="config-panel">
      <div id="configImatges">
        <div class="config-row">
          <label>Qualitat</label>
          <input type="range" id="qualityRange" min="0" max="100" value="80" />
          <span class="value" id="qualityValue">80</span>
          <label>Velocitat</label>
          <input type="range" id="speedRange" min="0" max="6" value="4" />
          <span class="value" id="speedValue">4</span>
          <label class="config-check" style="margin-left:.5rem">
            <input type="checkbox" id="losslessCheck" /> Sense pèrdua
            <span class="hint">Conserva tots els píxels. L'arxiu serà més gran.</span>
          </label>
        </div>
      </div>
      <div id="configVectors" class="hidden">
        <div class="config-row">
          <label>Precisió</label>
          <input type="range" id="precisionRange" min="0" max="10" value="3" />
          <span class="value" id="precisionValue">3</span>
        </div>
      </div>
      <div id="configFonts" class="hidden">
        <p style="color:var(--text2);font-size:.8rem">Converteix .ttf, .otf i .woff a WOFF2</p>
      </div>
    </div>

    <div class="browser-row">
      <div class="browser-col">
        <label class="section-label">Directori d'origen</label>
        <div class="browser">
          <div class="browser-tree" id="treeOrigen"></div>
          <div class="browser-footer">
            <span class="browser-path" id="pathOrigen">—</span>
            <button class="btn-reset" id="resetOrigen" type="button" title="Netejar selecció" disabled>✕</button>
            <label><input type="checkbox" id="recursiveCheck" /> Recursiu <span class="hint">Cerca dins de les subcarpetes.</span></label>
            <button class="btn-primary" id="scanBtn" type="button" disabled>Analitzar</button>
          </div>
        </div>
      </div>
      <div class="browser-col">
        <label class="section-label">Directori de sortida</label>
        <div class="browser">
          <div class="browser-tree" id="treeSortida"></div>
          <div class="browser-footer">
            <span class="browser-path" id="pathSortida">—</span>
            <button class="btn-reset" id="resetSortida" type="button" title="Netejar selecció" disabled>✕</button>
            <label><input type="checkbox" id="overwriteCheck" /> Sobreescriure <span class="hint">Si no, afegeix sufix _001, _002...</span></label>
            <button class="btn-primary" id="convertBtn" type="button" disabled>Convertir</button>
          </div>
        </div>
      </div>
    </div>

    <div class="gallery hidden" id="gallery"></div>
    <div class="file-list hidden" id="fileList"></div>
    <div class="status-log hidden" id="statusLog"></div>

    <footer class="footer">
      Creat amb ❤️ des de Catalunya per a la comunitat DEV · <a href="https://github.com/mutiny-cat/assets-converter" target="_blank">GitHub</a>
    </footer>
  </main>

  <script is:inline src="/app.js"></script>
</body>
</html>
